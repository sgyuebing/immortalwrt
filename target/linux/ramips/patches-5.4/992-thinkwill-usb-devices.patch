From 3a8d6f7e2d4e5b6a9c1d0f2e3b4a5c7d8e9f0a1 Mon Sep 17 00:00:00 2001
From: YourName <your@email.com>
Date: Fri, 1 Jan 2023 10:00:00 +0800
Subject: [PATCH] add support for ThinkWill ML7820 devices

---
 drivers/net/usb/cdc_ether.c     | 4 ++++
 drivers/net/usb/rndis_host.c    | 1 +
 drivers/usb/serial/option.c     | 6 +++++-
 3 files changed, 10 insertions(+), 1 deletion(-)

diff --git a/drivers/net/usb/cdc_ether.c b/drivers/net/usb/cdc_ether.c
index a1b2c3d4e..d4e5f6a7b 100644
--- a/drivers/net/usb/cdc_ether.c
+++ b/drivers/net/usb/cdc_ether.c
@@ -78,6 +78,10 @@ static const struct usb_device_id	products[] = {
 	.driver_info = 0,
 },
 
+/* ThinkWill ML7820 ECM */
+{ USB_DEVICE_AND_INTERFACE_INFO(0x19d2, 0x0199,
+	USB_CLASS_COMM, USB_CDC_SUBCLASS_ETHERNET, USB_CDC_PROTO_NONE) },
+
 /* Huawei ME906 and ME909 */
 { USB_DEVICE_AND_INTERFACE_INFO(0x12d1, 0x15c1,
 	USB_CLASS_COMM, USB_CDC_SUBCLASS_ETHERNET,
diff --git a/drivers/net/usb/rndis_host.c b/drivers/net/usb/rndis_host.c
index 7d8e9f0a1..a1b2c3d4e 100644
--- a/drivers/net/usb/rndis_host.c
+++ b/drivers/net/usb/rndis_host.c
@@ -622,6 +622,7 @@ static const struct usb_device_id	products [] = {
 	{ USB_DEVICE(0x05c6, 0x9025), },	/* Android */
 	{ USB_DEVICE(0x05c6, 0x9048), },	/* Android */
 	{ USB_DEVICE(0x05c6, 0x904c), },	/* Android */
+	{ USB_DEVICE(0x19d2, 0x0532), },	/* ThinkWill ML7820 NDIS */
 	{ USB_DEVICE(0x22b8, 0x2d70), },	/* Motorola Phone */
 	{ USB_DEVICE(0x22b8, 0x2e1a), },	/* Motorola Droid X */
 	{ USB_DEVICE(0x22b8, 0x2e24), },	/* Motorola Droid X */
diff --git a/drivers/usb/serial/option.c b/drivers/usb/serial/option.c
index d4e5f6a7b..a1b2c3d4e 100644
--- a/drivers/usb/serial/option.c
+++ b/drivers/usb/serial/option.c
@@ -240,6 +240,10 @@ static void option_instat_callback(struct urb *urb);
 #define THINKWILL_LTE_VENDOR_ID			0x19d2
 #define THINKWILL_PRODUCT_ML7820_ECM		0x0199
 #define THINKWILL_PRODUCT_ML7820_NDIS		0x0532
+#define THINKWILL_PRODUCT_ML7820_DL		0x0256
 
 static const struct usb_device_id option_ids[] = {
+	{ USB_DEVICE(THINKWILL_LTE_VENDOR_ID, THINKWILL_PRODUCT_ML7820_ECM) },
+	{ USB_DEVICE(THINKWILL_LTE_VENDOR_ID, THINKWILL_PRODUCT_ML7820_NDIS) },
+	{ USB_DEVICE(THINKWILL_LTE_VENDOR_ID, THINKWILL_PRODUCT_ML7820_DL) },
 	{ USB_DEVICE(OPTION_VENDOR_ID, OPTION_PRODUCT_COLT) },
 	{ USB_DEVICE(OPTION_VENDOR_ID, OPTION_PRODUCT_RICOLA) },
 	{ USB_DEVICE(OPTION_VENDOR_ID, OPTION_PRODUCT_RICOLA_LIGHT) },
-- 
2.34.1